{
  "name": "nethack3d",
  "version": "0.9.8",
  "main": "electron/main.cjs",
  "scripts": {
    "ensure:rollup-native": "node scripts/electron/ensure-rollup-native.mjs",
    "build": "npm run ensure:rollup-native && vite build",
    "build:capacitor": "npm run ensure:rollup-native && cross-env VITE_DEPLOY_TARGET=capacitor vite build",
    "build:electron": "npm run ensure:rollup-native && cross-env BUILD_TARGET=electron VITE_DEPLOY_TARGET=electron vite build",
    "updates:package": "node scripts/updates/prepare-client-update.mjs",
    "update": "npm run build && npm run updates:package",
    "dev": "npm run ensure:rollup-native && vite",
    "dev:isolated": "npm run ensure:rollup-native && cross-env NH3D_ENABLE_CROSS_ORIGIN_ISOLATION=true vite",
    "android:add": "cap add android",
    "android:sync": "npm run build:capacitor && cap sync android",
    "android:open": "cap open android",
    "android:run": "npm run build:capacitor && cap run android",
    "electron:dev": "cross-env VITE_DEPLOY_TARGET=electron VITE_DEV_SERVER_URL=http://127.0.0.1:5173 concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:dev:isolated": "cross-env VITE_DEPLOY_TARGET=electron NH3D_ENABLE_CROSS_ORIGIN_ISOLATION=true VITE_DEV_SERVER_URL=http://127.0.0.1:5173 concurrently -k \"npm run dev:isolated\" \"wait-on tcp:5173 && electron .\"",
    "electron:start": "electron .",
    "electron:pack:win": "npm run build:electron && electron-builder --win --x64 --dir",
    "electron:dist:win": "npm run build:electron && electron-builder --win nsis --x64",
    "electron:dist:win:portable": "npm run build:electron && electron-builder --win portable --x64",
    "electron:dist:linux:appimage": "node scripts/electron/dist-linux-appimage.mjs",
    "electron:dist:all": "node scripts/electron/dist-all.mjs",
    "electron:dist:all:parallel": "node scripts/electron/dist-all.mjs --parallel",
    "glyphs:generate": "node scripts/glyphs/generate-glyph-catalog.mjs",
    "glyphs:check": "node scripts/glyphs/check-glyph-catalog.mjs",
    "check:tsc": "tsc --noEmit --pretty false",
    "vulture:prebake": "node scripts/vulture/prebake-vulture-projections.mjs",
    "copy-wasm": "node scripts/wasm/copy-wasm.mjs",
    "start": "npm run dev",
    "start:preview": "vite preview",
    "preview": "vite preview",
    "preview:isolated": "cross-env NH3D_ENABLE_CROSS_ORIGIN_ISOLATION=true vite preview",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "NetHack 3D desktop build",
  "build": {
    "appId": "com.nethack3d.app",
    "productName": "NetHack 3D",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/@capacitor/core",
      "!node_modules/@capacitor/core/**",
      "!node_modules/@capacitor/android",
      "!node_modules/@capacitor/android/**"
    ],
    "linux": {
      "category": "Game",
      "icon": "build/icons",
      "desktop": {
        "entry": {
          "Comment": "Play NetHack in a fully interactive 3D dungeon.",
          "StartupWMClass": "nethack3d"
        }
      },
      "extraFiles": [
        {
          "from": "build/linux-libs",
          "to": ".",
          "filter": [
            "libcups.so.2"
          ]
        }
      ],
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "appImage": {
      "artifactName": "NetHack 3D ${version}.${ext}"
    },
    "win": {
      "icon": "public/NetHack3D.ico",
      "executableName": "NetHack 3D",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "NetHack 3D ${version} Setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "NetHack 3D ${version} Portable.${ext}",
      "useZip": true,
      "unpackDirName": false
    }
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@neth4ck/wasm-367": "^2.1.1",
    "@neth4ck/wasm-37": "^2.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.178.1",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "pngjs": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.94.0",
    "three": "^0.178.0",
    "typescript": "^5.8.3",
    "vite": "^5.4.10",
    "wait-on": "^9.0.4",
    "zustand": "^5.0.8"
  }
}
