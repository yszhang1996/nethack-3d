{
  "name": "nethack3d",
  "version": "0.8.6",
  "main": "electron/main.cjs",
  "scripts": {
    "build": "vite build",
    "build:electron": "cross-env BUILD_TARGET=electron vite build",
    "dev": "vite",
    "android:add": "cap add android",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:run": "npm run build && cap run android",
    "electron:dev": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:start": "electron .",
    "electron:pack:win": "npm run build:electron && electron-builder --win --x64 --dir",
    "electron:dist:win": "npm run build:electron && electron-builder --win nsis --x64",
    "electron:dist:win:portable": "npm run build:electron && electron-builder --win portable --x64",
    "glyphs:generate": "node scripts/glyphs/generate-glyph-catalog.mjs",
    "glyphs:check": "node scripts/glyphs/check-glyph-catalog.mjs",
    "copy-wasm": "node scripts/wasm/copy-wasm.mjs",
    "start": "vite",
    "start:preview": "vite preview",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "NetHack 3D desktop build",
  "build": {
    "appId": "com.nethack3d.app",
    "productName": "NetHack 3D",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "public/NetHack3D.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "NetHack ${version} Setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "NetHack ${version} Portable.${ext}"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@neth4ck/wasm-367": "^2.1.1",
    "@neth4ck/wasm-37": "^2.1.1",
    "@types/three": "^0.178.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.94.0",
    "three": "^0.178.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.10",
    "wait-on": "^9.0.4"
  }
}
